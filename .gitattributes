# GitHub Linguist: tell the language stats what to ignore.
# The dashboard is a build artifact (regenerated by `make dashboard`),
# so it should not count toward repo language totals. Same for figures
# and reports emitted by the pipeline.
dashboard/**    linguist-generated=true
figures/**      linguist-generated=true
reports/**.txt  linguist-generated=true

# Warehouse artifacts (kept out of git via .gitignore, but belt-and-braces).
warehouse/**    linguist-generated=true

# Notebooks are exploration, not source of truth.
notebooks/**    linguist-vendored=true
